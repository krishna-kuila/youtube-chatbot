{
  "manifest_version": 3,
  "name": "YouTube RAG Chat",
  "version": "1.0",
  "description": "Chat with the currently playing YouTube video.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}